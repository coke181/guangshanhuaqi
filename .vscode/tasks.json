{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Qt：配置（调试预设）",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "qt-msvc2022-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Qt：构建（调试预设）",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "qt-msvc2022-debug",
        "--target",
        "software_rasterizer"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Qt：配置（调试预设）",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
