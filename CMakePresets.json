{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "qt-msvc2022-debug",
      "displayName": "Soft Rasterizer / Qt 6.11 (MSVC2022, Debug)",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/presets/qt-msvc2022-debug",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "D:/QT/6.11.0/msvc2022_64"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "qt-msvc2022-debug",
      "configurePreset": "qt-msvc2022-debug",
      "configuration": "Debug"
    },
    {
      "name": "qt-msvc2022-relwithdebinfo",
      "configurePreset": "qt-msvc2022-debug",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "qt-msvc2022-release",
      "configurePreset": "qt-msvc2022-debug",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "qt-msvc2022-debug",
      "configurePreset": "qt-msvc2022-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "qt-msvc2022-relwithdebinfo",
      "configurePreset": "qt-msvc2022-debug",
      "configuration": "RelWithDebInfo",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "qt-msvc2022-release",
      "configurePreset": "qt-msvc2022-debug",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
